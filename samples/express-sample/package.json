{
    "name": "hiero-express-sample",
    "version": "1.0.0",
    "private": true,
    "description": "Sample Express app using @hiero-enterprise/express",
    "type": "module",
    "scripts": {
        "dev": "tsx --env-file-if-exists=.env src/app.ts",
        "build": "tsc",
        "start": "node --env-file-if-exists=.env dist/app.js"
    },
    "dependencies": {
        "@hiero-enterprise/express": "workspace:*",
        "express": "^5.1.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.9.0"
    }
}

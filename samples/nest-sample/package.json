{
    "name": "hiero-nest-sample",
    "version": "1.0.0",
    "private": true,
    "description": "Sample NestJS app using @hiero-enterprise/nest",
    "type": "module",
    "scripts": {
        "dev": "tsx --env-file-if-exists=.env src/main.ts",
        "build": "tsc",
        "start": "node --env-file-if-exists=.env dist/main.js"
    },
    "dependencies": {
        "@hiero-enterprise/nest": "workspace:*",
        "@nestjs/common": "^11.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "reflect-metadata": "^0.2.0"
    },
    "devDependencies": {
        "tsx": "^4.0.0",
        "typescript": "^5.9.0"
    }
}
